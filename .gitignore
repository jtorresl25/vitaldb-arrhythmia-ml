# ============================================================================
# Datos crudos, intermedios y procesados (NUNCA subir al repositorio).
# Se ignora el contenido pero se conservan los `.gitkeep` para preservar la
# estructura del repositorio.
# ============================================================================
data/raw/*
data/interim/*
data/processed/*

# Mantener subcarpetas vacías de data/raw/
!data/raw/physionet_annotations/
!data/raw/vitaldb_waveforms/
data/raw/physionet_annotations/*
data/raw/vitaldb_waveforms/*
!data/raw/physionet_annotations/.gitkeep
!data/raw/vitaldb_waveforms/.gitkeep

# Mantener .gitkeep en data/raw, data/interim y data/processed
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

