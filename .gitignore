# ============================================================================
# Modelos entrenados
# ============================================================================

# Formatos de modelo en cualquier otra ubicación del repo
*.pt
*.pth
*.onnx
*.bin
*.pb
*.ckpt
*.safetensors

# Artefactos de models/ necesarios para la app Streamlit — se incluyen en Git.
# Estas excepciones deben ir DESPUÉS de *.joblib para tener precedencia.
!models/README.md
!models/*.joblib

# ============================================================================
# Artefactos de Streamlit Cloud — frontend/app/app_artifacts/ se incluye en Git.
# Las excepciones deben ir DESPUES de las reglas globales para tener precedencia.
!frontend/app/app_artifacts/
!frontend/app/app_artifacts/**
!frontend/app/app_artifacts/models/
!frontend/app/app_artifacts/models/**
!frontend/app/app_artifacts/reports/
!frontend/app/app_artifacts/reports/**
!frontend/app/app_artifacts/reports/tables/
!frontend/app/app_artifacts/reports/tables/**
!frontend/app/app_artifacts/reports/figures/
!frontend/app/app_artifacts/reports/figures/**
!frontend/app/app_artifacts/demo/
!frontend/app/app_artifacts/demo/**
!frontend/app/app_artifacts/demo/case_features/
!frontend/app/app_artifacts/demo/case_features/**
!frontend/app/app_artifacts/demo/npy_cases/
!frontend/app/app_artifacts/demo/npy_cases/**

# ============================================================================
# Reportes generados automáticamente
# ============================================================================
reports/figures/*
reports/tables/*
!reports/figures/.gitkeep
!reports/tables/.gitkeep

